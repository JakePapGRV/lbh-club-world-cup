# Postgres connection string.
# On Render this is injected automatically when the DB is linked (see render.yaml).
# Locally, point it at your own Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/worldcup

# Password that protects the admin/draft controls and the score override page.
ADMIN_PASSWORD=change-me

# Secret used to sign session cookies. Render generates this automatically.
SESSION_SECRET=change-me-too

# Free API token from https://www.football-data.org/client/register
# Leave blank to run the test draft without live scores.
FOOTBALL_DATA_TOKEN=

# How often to poll the API for score updates (cron syntax). Default: every 5 minutes.
SCORE_SYNC_CRON=*/5 * * * *
